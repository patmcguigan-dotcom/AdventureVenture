<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>8-Bit Adventure - V9.2 Mobile</title>
    <style>
        body { margin: 0; overflow: hidden; background: #050505; font-family: 'Courier New', monospace; touch-action: none; }
        #game-container { width: 100vw; height: 100vh; }
        
        /* CRT Effects */
        .crt-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            background-size: 100% 3px, 2px 100%;
            pointer-events: none; z-index: 10;
        }

        /* Virtual Joystick UI */
        #joystick-base {
            position: absolute; width: 80px; height: 80px;
            background: rgba(0, 255, 0, 0.1); border: 2px solid rgba(0, 255, 0, 0.3);
            border-radius: 50%; display: none; pointer-events: none; z-index: 5;
        }
        #joystick-knob {
            position: absolute; width: 30px; height: 30px;
            background: rgba(0, 255, 0, 0.5); border-radius: 50%;
            transform: translate(-50%, -50%);
        }
    </style>
</head>
<body>
    <div class="crt-overlay"></div>
    <div id="joystick-base"><div id="joystick-knob"></div></div>
    <div id="game-container"></div>

    <script type="importmap">
        { "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }
    </script>
    <script type="module">
        import * as THREE from 'three';

        // --- SCENE SETUP ---
        const scene = new THREE.Scene();
        const aspect = window.innerWidth / window.innerHeight;
        const d = 5;
        const camera = new THREE.OrthographicCamera(-d * aspect, d * aspect, d, -d, 0.1, 1000);
        camera.position.z = 10;

        const renderer = new THREE.WebGLRenderer({ antialias: false });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.getElementById('game-container').appendChild(renderer.domElement);

        // --- GAME STATE ---
        let moveSpeed = 0.15;
        const targetWorldPos = new THREE.Vector3(0, 0, 0);
        const worldGroup = new THREE.Group();
        scene.add(worldGroup);

        // --- WORLD ASSETS ---
        const grid = new THREE.GridHelper(30, 30, 0x004400, 0x111111);
        grid.rotation.x = Math.PI / 2;
        worldGroup.add(grid);

        // Speed Boost (The Objective)
        const boostGeo = new THREE.PlaneGeometry(0.5, 0.5);
        const boostMat = new THREE.MeshBasicMaterial({ color: 0xffff00 });
        const speedBoost = new THREE.Mesh(boostGeo, boostMat);
        speedBoost.position.set(4, 4, 0); 
        worldGroup.add(speedBoost);

        // Player Icon (Fixed Center)
        const playerGeo = new THREE.PlaneGeometry(0.5, 0.5);
        const playerMat = new THREE.MeshBasicMaterial({ color: 0x00ff00 });
        const playerIcon = new THREE.Mesh(playerGeo, playerMat);
        scene.add(playerIcon);

        // --- INPUT LOGIC ---
        const keys = {};
        const touch = { active: false, start: new THREE.Vector2(), current: new THREE.Vector2() };
        const joyBase = document.getElementById('joystick-base');
        const joyKnob = document.getElementById('joystick-knob');

        window.addEventListener('keydown', (e) => keys[e.code] = true);
        window.addEventListener('keyup', (e) => keys[e.code] = false);

        window.addEventListener('touchstart', (e) => {
            touch.active = true;
            touch.start.set(e.touches[0].clientX, e.touches[0].clientY);
            joyBase.style.display = 'block';
            joyBase.style.left = `${touch.start.x - 40}px`;
            joyBase.style.top = `${touch.start.y - 40}px`;
        });

        window.addEventListener('touchmove', (e) => {
            if (!touch.active) return;
            touch.current.set(e.touches[0].clientX, e.touches[0].clientY);
            const dist = touch.start.distanceTo(touch.current);
            const maxDist = 40;
            const clampedDist = Math.min(dist, maxDist);
            const angle = Math.atan2(touch.current.y - touch.start.y, touch.current.x - touch.start.x);
            
            joyKnob.style.left = `${40 + Math.cos(angle) * clampedDist}px`;
            joyKnob.style.top = `${40 + Math.sin(angle) * clampedDist}px`;
        });

        window.addEventListener('touchend', () => {
            touch.active = false;
            joyBase.style.display = 'none';
        });

        // --- MAIN LOOP ---
        function animate() {
            requestAnimationFrame(animate);

            // Keyboard Movement
            if (keys['ArrowUp'] || keys['KeyW']) targetWorldPos.y -= moveSpeed;
            if (keys['ArrowDown'] || keys['KeyS']) targetWorldPos.y += moveSpeed;
            if (keys['ArrowLeft'] || keys['KeyA']) targetWorldPos.x += moveSpeed;
            if (keys['ArrowRight'] || keys['KeyD']) targetWorldPos.x -= moveSpeed;

            // Touch Movement Logic
            if (touch.active) {
                const dir = new THREE.Vector2().subVectors(touch.current, touch.start).normalize();
                const dist = Math.min(touch.start.distanceTo(touch.current) / 40, 1);
                targetWorldPos.x -= dir.x * moveSpeed * dist;
                targetWorldPos.y += dir.y * moveSpeed * dist;
            }

            // v9.2 Smoothing
            worldGroup.position.lerp(targetWorldPos, 0.15);

            // Pickup Check
            const boostWorldPos = new THREE.Vector3();
            speedBoost.getWorldPosition(boostWorldPos);
            if (boostWorldPos.distanceTo(new THREE.Vector3(0,0,0)) < 0.4 && speedBoost.visible) {
                speedBoost.visible = false;
                moveSpeed = 0.35; // Double Speed
            }

            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            const aspect = window.innerWidth / window.innerHeight;
            camera.left = -d * aspect; camera.right = d * aspect;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
